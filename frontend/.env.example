# Copy this file to .env for local development (that file is gitignored).
# Only PUBLIC/publishable values belong here — Expo inlines EXPO_PUBLIC_* vars into the
# client bundle, so anything secret (Vision API key, Razorpay key secret) must live on
# the backend only (see backend/.dev.vars.example), never here.

EXPO_PUBLIC_API_BASE_URL=http://10.113.19.23:8787

# Razorpay's publishable key id (safe for client-side), used to open the checkout — see Phase 10.
EXPO_PUBLIC_RAZORPAY_KEY_ID=
