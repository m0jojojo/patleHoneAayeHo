# Copy this file to .dev.vars for local development (that file is gitignored).
# In production, set these as Worker secrets: `wrangler secret put <NAME>`.

# Vision API (dish identification + portion estimation) — Gemini was chosen, see
# docs/meal-scanning.md for why and how to swap providers. Not used yet: vision calls are
# stubbed (backend/src/vision/provider.ts) until this is actually wired up and a real key is set.
GEMINI_API_KEY=

# Razorpay (UPI payments) — wired up in Phase 10, scaffolded here so the shape exists early.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# D1 (SQLite at the edge) is bound in wrangler.jsonc via the `d1_databases` config,
# not via an env var/connection string — no DB credential belongs here.
